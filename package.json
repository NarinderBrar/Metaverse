{
  "name": "multiplayer-cube-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/server.ts",
    "start": "tsx server/server.ts",
    "test:socket": "node scripts/socket-smoke.mjs",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "latest",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/three": "latest",
    "concurrently": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
